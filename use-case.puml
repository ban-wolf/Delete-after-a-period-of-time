@startuml
left to right direction
skinparam defaultFontName Microsoft YaHei
skinparam shadowing false

actor 用户 as User
actor 管理员 as Admin

rectangle "图书角管理系统" {
  usecase "搜索图书" as UC1
  usecase "查看图书信息" as UC2
  usecase "借阅图书" as UC3
  usecase "归还图书" as UC4
  usecase "录入图书信息" as UC5
  usecase "修改图书信息" as UC6
  usecase "删除图书信息" as UC7
  usecase "登记借阅记录" as UC8
  usecase "登记归还记录" as UC9
}

User --> UC1
User --> UC2
User --> UC3
User --> UC4

Admin --> UC5
Admin --> UC6
Admin --> UC7
Admin --> UC8
Admin --> UC9

UC3 ..> UC8 : <<include>>
UC4 ..> UC9 : <<include>>
@enduml
